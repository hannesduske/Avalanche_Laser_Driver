	(text "Enable Network"
		(exclude_from_sim no)
		(at 255.016 100.838 0)
		(effects
			(font
				(size 1.778 1.778)
				(thickness 0.3556)
				(bold yes)
			)
		)
		(uuid "3d37507d-b59b-4525-be3e-a667ab6eeb19")
	)
	(text "The reference voltage of EN and FBX are 1.6V:\n- Cutoff input voltage is 7.5V with selected resistors on EN\n- Output is adjustable from 100V to 260V with selected resistors on FBX\n\nPoti RV1 terminal 2 and 3 tied together that the poti can't fail open circuit\n→ limits VCC_HV in case of poti failure\n\n\nRT=130k compared to 107k in other designs\n→ f=330kHz, larger off-time-margin which would be near the limit at 400kHz,\n  increased ripple doesn't matter because we're just charging the power caps with the output"
		(exclude_from_sim no)
		(at 15.494 183.642 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "49e3b5e0-d0ee-4d8e-855f-9afe39dcb95b")
	)
	(text "Reference design:        74437324100  (10uH, 120V)\nAvailable alternative:     74438336100  (10uH, 80V, tiny)\nAvailable alternative:     74438356150  (15uH, 80V)\nBetter alternative:        74438356220  (22uH, 80V)\nNew replacement part:    7443732448100 (10uH, 120V)\nPerformance alternative:  744393305220 (22uH, 120V?)"
		(exclude_from_sim no)
		(at 83.058 70.104 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "5727f814-c922-43eb-b62f-ad889a3cfdbb")
	)
